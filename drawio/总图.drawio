        </mxCell>
        <mxCell id="vo7ysrC7n_gt9XxNnj0G-140" value="&lt;span style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;序号 Sequence：生产者、&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 30px; font-weight: 700; background-color: initial;&quot;&gt;消费者&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;生产者生产时：需要监控消费者，避免覆盖上一轮已写入的数据&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;消费者消费时：需要监控生产者，避免拿到上一轮已消费的数据&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;&lt;font color=&quot;#0000ff&quot;&gt;因此生产者和消费者都会持有：生产者序号 A + 消费者序号 B&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;div style=&quot;font-size: 30px; font-weight: 700;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;写入 A 时保证有序性：避免 B 缓存失效&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 30px; font-weight: 700;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;读取 B 时保证可见性：强一致读取 B 并缓存&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontColor=#FF0000;fontFamily=Verdana;" parent="1" vertex="1">
          <mxGeometry x="3052" y="-545" width="845" height="269" as="geometry" />
        </mxCell>
        <mxCell id="QtlnAmtoOxbIfB7pYeYJ-36" value="&lt;div&gt;&lt;div&gt;cursor 多线程生产者共同的已申请序号（可能未发布）&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;多线程生产者 M1、M2、M3、M4&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;它们会通过 CAS&amp;nbsp;&lt;/span&gt;cursor&amp;nbsp;&lt;span style=&quot;background-color: initial;&quot;&gt;来争抢可生产序号（M&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;′&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&amp;nbsp;已申请、M 已发布）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;当 M4′ 完成生产后需要 &quot;发布事件&quot;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;设置&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;availableBuffer[s&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;equence % bufferSize&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;] = s&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;equence / bufferSize&lt;/span&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontColor=#000000;fontFamily=Verdana;" parent="1" vertex="1">
          <mxGeometry x="2733.04" y="3005" width="701" height="179" as="geometry" />
        </mxCell>
        <mxCell id="QtlnAmtoOxbIfB7pYeYJ-37" value="" style="group" parent="1" vertex="1" connectable="0">
          <mxGeometry x="1813.04" y="3276" width="1512.4700000000003" height="610.8890497060197" as="geometry" />
        </mxCell>
        <mxCell id="vo7ysrC7n_gt9XxNnj0G-80" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffcccc;strokeColor=#36393d;rotation=342;" parent="QtlnAmtoOxbIfB7pYeYJ-37" vertex="1">
          <mxGeometry x="496.9800000000005" y="308" width="463.98" height="237" as="geometry" />
        </mxCell>
        <mxCell id="vo7ysrC7n_gt9XxNnj0G-81" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=0;exitY=1;exitDx=0;exitDy=0;" parent="QtlnAmtoOxbIfB7pYeYJ-37" source="vo7ysrC7n_gt9XxNnj0G-129" target="vo7ysrC7n_gt9XxNnj0G-108" edge="1">
